# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306 # MySQL 기본 포트. 사용하시는 MySQL 설정에 따라 다를 수 있습니다.
DB_USERNAME=root # MySQL 사용자명. 실제 사용자에 맞춰 변경하세요.
DB_PASSWORD=your_mysql_password # MySQL 비밀번호. 실제 비밀번호로 변경하세요.
DB_DATABASE=tastebox_db # 사용할 데이터베이스 이름. 미리 생성해두세요.

# TMDb API Configuration
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE # TMDb 개발자 웹사이트에서 발급받은 API 키를 여기에 입력하세요.
TMDB_BASE_URL=https://api.themoviedb.org/3 # TMDb API의 기본 URL
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/ # TMDb 이미지 서비스 기본 URL (상대 경로를 완전한 URL로 만듦)